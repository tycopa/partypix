@page "{code:int?}"
@model ErrorModel
@{
    ViewData["Title"] = "Something went wrong";
    Layout = "_Layout";
}
<section class="mx-auto max-w-2xl px-4 py-20 text-center">
    <h1 class="text-3xl font-semibold text-bronze">@(Model.Code?.ToString() ?? "Error")</h1>
    <p class="mt-2 text-ink">@Model.Message</p>
    <a href="/" class="mt-6 inline-block text-bronze hover:underline">Go home</a>
</section>
