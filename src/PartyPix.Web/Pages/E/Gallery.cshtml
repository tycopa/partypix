@page "/e/{slug}/gallery"
@model PartyPix.Web.Pages.E.GalleryModel
@{
    Layout = "_GuestLayout";
    ViewData["Title"] = Model.Event.Title;
}

<section class="py-6">
    <div class="flex items-start justify-between gap-4">
        <div>
            <h1 class="text-2xl font-semibold tracking-tight">@Model.Event.Title</h1>
            <p class="text-sm text-slate-400">Hi, @Model.Guest.DisplayName · @Model.Media.Count items</p>
        </div>
        @if (Model.Event.GuestUploadsEnabled)
        {
            <a asp-page="/E/Upload" asp-route-slug="@Model.Event.Slug"
               class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500">
                Add photos
            </a>
        }
    </div>

    @if (!Model.Media.Any())
    {
        <div class="mt-16 rounded-lg border border-dashed border-slate-700 p-10 text-center">
            <p class="text-slate-400">No photos yet. Be the first!</p>
            @if (Model.Event.GuestUploadsEnabled)
            {
                <a asp-page="/E/Upload" asp-route-slug="@Model.Event.Slug"
                   class="mt-3 inline-block text-indigo-400 hover:underline">Upload photos</a>
            }
        </div>
    }
    else
    {
        <div id="gallery" class="mt-6 grid grid-cols-2 gap-1 sm:grid-cols-3 md:grid-cols-4">
            @foreach (var m in Model.Media)
            {
                <a href="/media/@m.Id/display" target="_blank"
                   class="aspect-square overflow-hidden rounded-md bg-slate-800">
                    <img src="/media/@m.Id/thumb" alt="" class="h-full w-full object-cover" loading="lazy" />
                </a>
            }
        </div>
    }
</section>

@section Scripts {
<script src="https://unpkg.com/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
<script>
(function () {
    const slug = "@Model.Event.Slug";
    const gallery = document.getElementById("gallery");
    if (!gallery) return;
    const conn = new signalR.HubConnectionBuilder().withUrl("/hubs/slideshow").withAutomaticReconnect().build();
    conn.on("mediaAdded", (payload) => {
        const a = document.createElement("a");
        a.href = "/media/" + payload.mediaId + "/display";
        a.target = "_blank";
        a.className = "aspect-square overflow-hidden rounded-md bg-slate-800";
        a.innerHTML = '<img src="/media/' + payload.mediaId + '/thumb" class="h-full w-full object-cover" loading="lazy" />';
        gallery.prepend(a);
    });
    conn.start().then(() => conn.invoke("JoinEvent", slug)).catch(console.error);
})();
</script>
}
