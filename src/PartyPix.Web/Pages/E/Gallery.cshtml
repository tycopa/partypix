@page "/e/{slug}/gallery"
@using System.Text.Json
@model PartyPix.Web.Pages.E.GalleryModel
@{
    Layout = "_GuestLayout";
    ViewData["Title"] = Model.Event.Title;
    var initialItems = JsonSerializer.Serialize(
        Model.Media.Select(m => new { id = m.Id, kind = (int)m.Kind }));
}

<section class="py-6"
         x-data="gallery({ items: @initialItems })"
         @@media-added.window="addItem($event.detail)">
    <div class="flex items-start justify-between gap-4">
        <div>
            <h1 class="text-2xl font-semibold tracking-tight">@Model.Event.Title</h1>
            <p class="text-sm text-slate-400">
                Hi, @Model.Guest.DisplayName · <span x-text="items.length"></span> items
            </p>
        </div>
        @if (Model.Event.GuestUploadsEnabled)
        {
            <a asp-page="/E/Upload" asp-route-slug="@Model.Event.Slug"
               class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500">
                Add photos
            </a>
        }
    </div>

    <div x-show="items.length === 0"
         class="mt-16 rounded-lg border border-dashed border-slate-700 p-10 text-center">
        <p class="text-slate-400">No photos yet. Be the first!</p>
        @if (Model.Event.GuestUploadsEnabled)
        {
            <a asp-page="/E/Upload" asp-route-slug="@Model.Event.Slug"
               class="mt-3 inline-block text-indigo-400 hover:underline">Upload photos</a>
        }
    </div>

    <div x-show="items.length > 0"
         class="mt-6 grid grid-cols-2 gap-1 sm:grid-cols-3 md:grid-cols-4">
        <template x-for="(item, i) in items" :key="item.id">
            <button type="button" @@click="open(i)"
                    class="aspect-square overflow-hidden rounded-md bg-slate-800 focus:outline-none focus:ring-2 focus:ring-indigo-500">
                <img :src="'/media/' + item.id + '/thumb'" alt=""
                     class="h-full w-full object-cover" loading="lazy" />
            </button>
        </template>
    </div>

    <!-- Lightbox -->
    <div x-cloak
         x-show="index !== null"
         x-transition.opacity
         @@keydown.escape.window="close()"
         @@keydown.arrow-left.window="prev()"
         @@keydown.arrow-right.window="next()"
         @@click.self="close()"
         class="fixed inset-0 z-50 flex items-center justify-center bg-black/90 p-4">
        <button type="button" @@click.stop="close()" aria-label="Close"
                class="absolute right-4 top-4 rounded-full bg-white/10 p-2 text-white hover:bg-white/20">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" class="h-6 w-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M6 18L18 6" />
            </svg>
        </button>

        <button type="button" @@click.stop="prev()" aria-label="Previous"
                x-show="items.length > 1"
                class="absolute left-2 sm:left-4 rounded-full bg-white/10 p-2 text-white hover:bg-white/20">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" class="h-7 w-7">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 18l-6-6 6-6" />
            </svg>
        </button>

        <button type="button" @@click.stop="next()" aria-label="Next"
                x-show="items.length > 1"
                class="absolute right-2 sm:right-4 rounded-full bg-white/10 p-2 text-white hover:bg-white/20">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" class="h-7 w-7">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 6l6 6-6 6" />
            </svg>
        </button>

        <img x-show="index !== null"
             :src="index !== null ? ('/media/' + items[index].id + '/display') : ''"
             alt=""
             class="max-h-[90vh] max-w-[95vw] object-contain"
             @@click.stop />

        <div x-show="items.length > 1"
             class="absolute bottom-4 left-1/2 -translate-x-1/2 rounded-full bg-white/10 px-3 py-1 text-xs text-white">
            <span x-text="(index ?? 0) + 1"></span> / <span x-text="items.length"></span>
        </div>
    </div>
</section>

@section Scripts {
<script src="https://unpkg.com/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
<script>
function gallery({ items }) {
    return {
        items,
        index: null,
        open(i) {
            this.index = i;
            document.body.style.overflow = "hidden";
        },
        close() {
            this.index = null;
            document.body.style.overflow = "";
        },
        next() {
            if (this.index === null || this.items.length === 0) return;
            this.index = (this.index + 1) % this.items.length;
        },
        prev() {
            if (this.index === null || this.items.length === 0) return;
            this.index = (this.index - 1 + this.items.length) % this.items.length;
        },
        addItem(item) {
            if (!item || !item.id) return;
            if (this.items.some(x => x.id === item.id)) return;
            this.items.unshift({ id: item.id, kind: item.kind ?? 0 });
            // Keep the currently viewed photo in focus after a prepend.
            if (this.index !== null) this.index += 1;
        },
    };
}

(function () {
    const slug = "@Model.Event.Slug";
    const conn = new signalR.HubConnectionBuilder()
        .withUrl("/hubs/slideshow")
        .withAutomaticReconnect()
        .build();
    conn.on("mediaAdded", (payload) => {
        window.dispatchEvent(new CustomEvent("media-added", {
            detail: { id: payload.mediaId, kind: payload.kind ?? 0 },
        }));
    });
    conn.start().then(() => conn.invoke("JoinEvent", slug)).catch(console.error);
})();
</script>
}
