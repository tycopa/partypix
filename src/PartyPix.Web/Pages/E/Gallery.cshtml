@page "/e/{slug}/gallery"
@using System.Text.Json
@model PartyPix.Web.Pages.E.GalleryModel
@{
    Layout = "_GuestLayout";
    ViewData["Title"] = Model.Event.Title;
    var initialItems = JsonSerializer.Serialize(
        Model.Items.Select(i => new { id = i.Id, kind = i.Kind, uploaderName = i.UploaderName }));
}

<section class="py-6"
         x-data="galleryLightbox({ items: @initialItems })"
         @@media-added.window="addItem($event.detail)">
    <div class="flex items-start justify-between gap-4">
        <div>
            <h1 class="text-2xl font-semibold tracking-tight text-bronze">@Model.Event.Title</h1>
            <p class="text-sm text-ink-soft">
                Hi, <span class="text-ink">@Model.Guest.DisplayName</span> · @Model.TotalCount items
            </p>
        </div>
        @if (Model.Event.GuestUploadsEnabled)
        {
            <a asp-page="/E/Upload" asp-route-slug="@Model.Event.Slug"
               class="rounded-md bg-bronze px-4 py-2 text-sm font-medium text-white hover:bg-bronze-deep">
                Add photos
            </a>
        }
    </div>

    <div x-show="items.length === 0"
         class="mt-16 rounded-lg border border-dashed border-bronze/40 p-10 text-center">
        <p class="text-ink-soft">No photos yet. Be the first!</p>
        @if (Model.Event.GuestUploadsEnabled)
        {
            <a asp-page="/E/Upload" asp-route-slug="@Model.Event.Slug"
               class="mt-3 inline-block text-bronze hover:underline">Upload photos</a>
        }
    </div>

    <div x-show="items.length > 0"
         class="mt-6 grid grid-cols-2 gap-1 sm:grid-cols-3 md:grid-cols-4">
        <template x-for="(item, i) in items" :key="item.id">
            <button type="button" @@click="open(i)"
                    :class="item.kind === 1 ? 'bg-ink' : 'bg-white'"
                    class="relative aspect-square overflow-hidden rounded-md ring-1 ring-bronze/15 focus:outline-none focus:ring-2 focus:ring-bronze">
                <img :src="'/media/' + item.id + '/thumb'" alt=""
                     class="h-full w-full object-cover" loading="lazy"
                     @@error="$event.target.style.visibility='hidden'" />
                <span x-show="item.kind === 1"
                      class="pointer-events-none absolute inset-0 flex items-center justify-center bg-black/30">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="h-10 w-10 drop-shadow">
                        <path d="M8 5v14l11-7L8 5z" />
                    </svg>
                </span>
            </button>
        </template>
    </div>

    <partial name="_GalleryLightbox" />

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-8 flex items-center justify-center gap-3 text-sm">
            @if (Model.CurrentPage > 1)
            {
                <a asp-route-slug="@Model.Event.Slug" asp-route-p="@(Model.CurrentPage - 1)"
                   class="rounded-md border border-bronze/30 bg-white px-3 py-1.5 text-ink hover:bg-parchment">
                    &larr; Previous
                </a>
            }
            else
            {
                <span class="rounded-md border border-bronze/15 px-3 py-1.5 text-ink-soft/60">&larr; Previous</span>
            }

            <span class="text-ink-soft">Page @Model.CurrentPage of @Model.TotalPages</span>

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <a asp-route-slug="@Model.Event.Slug" asp-route-p="@(Model.CurrentPage + 1)"
                   class="rounded-md border border-bronze/30 bg-white px-3 py-1.5 text-ink hover:bg-parchment">
                    Next &rarr;
                </a>
            }
            else
            {
                <span class="rounded-md border border-bronze/15 px-3 py-1.5 text-ink-soft/60">Next &rarr;</span>
            }
        </nav>
    }
</section>

@section Scripts {
<script src="~/js/gallery-lightbox.js" asp-append-version="true"></script>
<script src="https://unpkg.com/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
<script>
(function () {
    const slug = "@Model.Event.Slug";
    const currentPage = @Model.CurrentPage;
    const conn = new signalR.HubConnectionBuilder()
        .withUrl("/hubs/slideshow")
        .withAutomaticReconnect()
        .build();
    conn.on("mediaAdded", (payload) => {
        // Only the first page reflects live uploads; on later pages a
        // prepend would shove a "newest" item into the middle of a window
        // that's supposed to show older items.
        if (currentPage !== 1) return;
        window.dispatchEvent(new CustomEvent("media-added", {
            detail: {
                id: payload.mediaId,
                kind: payload.kind ?? 0,
                uploaderName: payload.uploaderName ?? null,
            },
        }));
    });
    conn.start().then(() => conn.invoke("JoinEvent", slug)).catch(console.error);
})();
</script>
}
