@page
@model IndexModel
@{
    ViewData["Title"] = "PartyPix — shared event photos";
}

<section class="mx-auto max-w-5xl px-4 py-16">
    <div class="grid gap-12 md:grid-cols-2 md:items-center">
        <div>
            <h1 class="text-4xl font-semibold tracking-tight sm:text-5xl">
                Everyone's photos from the night, in one place.
            </h1>
            <p class="mt-4 text-lg text-slate-600">
                Print a QR code. Guests scan, add their name, and drop photos and
                videos into a shared gallery. No apps, no sign-ups, no AirDrop
                chaos the next morning.
            </p>
            <div class="mt-6 flex gap-3">
                <a href="/Identity/Account/Register"
                   class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500">
                    Create an event
                </a>
                <a href="/Identity/Account/Login"
                   class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">
                    Sign in
                </a>
            </div>
        </div>
        <div class="rounded-2xl bg-white p-8 shadow-sm ring-1 ring-slate-200">
            <ol class="space-y-4 text-sm">
                <li class="flex gap-3"><span class="flex h-6 w-6 items-center justify-center rounded-full bg-indigo-100 text-indigo-700">1</span> Create an event and print the QR.</li>
                <li class="flex gap-3"><span class="flex h-6 w-6 items-center justify-center rounded-full bg-indigo-100 text-indigo-700">2</span> Guests scan and upload from their camera roll.</li>
                <li class="flex gap-3"><span class="flex h-6 w-6 items-center justify-center rounded-full bg-indigo-100 text-indigo-700">3</span> Stream a live slideshow on the big screen.</li>
                <li class="flex gap-3"><span class="flex h-6 w-6 items-center justify-center rounded-full bg-indigo-100 text-indigo-700">4</span> Download everything in full resolution.</li>
            </ol>
        </div>
    </div>
</section>
