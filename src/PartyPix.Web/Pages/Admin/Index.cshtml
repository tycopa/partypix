@page
@model PartyPix.Web.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Your events";
}

<section class="mx-auto max-w-5xl px-4 py-10">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-semibold text-bronze">Your events</h1>
        <a asp-page="/Admin/Events/Create"
           class="rounded-md bg-bronze px-4 py-2 text-sm font-medium text-white hover:bg-bronze-deep">
            New event
        </a>
    </div>

    @if (!Model.Events.Any())
    {
        <div class="mt-10 rounded-lg border border-dashed border-bronze/40 bg-white p-10 text-center">
            <p class="text-ink-soft">You haven&rsquo;t created an event yet.</p>
            <a asp-page="/Admin/Events/Create" class="mt-3 inline-block text-bronze hover:underline">
                Create your first event
            </a>
        </div>
    }
    else
    {
        <ul class="mt-6 grid gap-4 sm:grid-cols-2">
            @foreach (var ev in Model.Events)
            {
                <li class="rounded-lg bg-white p-5 shadow-sm ring-1 ring-bronze/15">
                    <div class="flex items-start justify-between gap-4">
                        <div>
                            <h2 class="font-medium text-ink">@ev.Title</h2>
                            <p class="text-sm text-ink-soft">@ev.EventDate.ToString("MMM d, yyyy")</p>
                        </div>
                        <a asp-page="/Admin/Events/Detail" asp-route-slug="@ev.Slug"
                           class="text-sm text-bronze hover:underline">Manage</a>
                    </div>
                </li>
            }
        </ul>
    }
</section>
