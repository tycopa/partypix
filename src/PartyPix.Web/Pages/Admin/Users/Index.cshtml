@page
@model PartyPix.Web.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "Users";
}

<section class="mx-auto max-w-5xl px-4 py-10"
         x-data="{ resetFor: null, deleteFor: null, newPassword: '', confirmEmail: '' }">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-semibold text-bronze">Users</h1>
        <a href="/Identity/Account/Register"
           class="rounded-md bg-bronze px-4 py-2 text-sm font-medium text-white hover:bg-bronze-deep">
            Add user
        </a>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="mt-4 rounded-md bg-green-50 p-3 text-sm text-green-700">@Model.StatusMessage</div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="mt-4 rounded-md bg-red-50 p-3 text-sm text-red-700">@Model.ErrorMessage</div>
    }

    <ul class="mt-6 divide-y divide-bronze/15 rounded-lg bg-white shadow-sm ring-1 ring-bronze/15">
        @foreach (var u in Model.Users)
        {
            <li class="flex flex-wrap items-center justify-between gap-3 px-5 py-4">
                <div>
                    <div class="font-medium text-ink">@u.Email</div>
                    <div class="text-xs text-ink-soft">
                        Joined @u.CreatedAt.ToString("MMM d, yyyy")
                        @if (u.IsAdmin)
                        {
                            <span class="ml-2 rounded-full bg-bronze/15 px-2 py-0.5 text-bronze">admin</span>
                        }
                    </div>
                </div>
                <div class="flex gap-2">
                    <button type="button"
                            @@click="resetFor = '@u.Id'; newPassword = ''"
                            class="rounded-md border border-bronze/30 bg-white px-3 py-1.5 text-sm text-ink hover:bg-parchment">
                        Reset password
                    </button>
                    <button type="button"
                            @@click="deleteFor = '@u.Id'; confirmEmail = ''"
                            class="rounded-md border border-red-700/30 bg-white px-3 py-1.5 text-sm text-red-700 hover:bg-red-50">
                        Delete
                    </button>
                </div>
            </li>
        }
    </ul>

    <!-- Reset password modal -->
    <div x-cloak x-show="resetFor !== null"
         class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 p-4"
         @@keydown.escape.window="resetFor = null"
         @@click.self="resetFor = null">
        <div class="w-full max-w-sm rounded-lg bg-white p-6 shadow-xl ring-1 ring-bronze/20">
            <h3 class="text-lg font-semibold text-bronze">Reset password</h3>
            <p class="mt-2 text-sm text-ink-soft">
                Set a new password for this user. Tell them the new password
                in person — it won&rsquo;t be emailed.
            </p>
            <form method="post" asp-page-handler="ResetPassword" class="mt-4 space-y-3">
                <input type="hidden" name="Input.UserId" :value="resetFor" />
                <label class="block text-sm font-medium text-ink">New password</label>
                <input type="password" name="Input.NewPassword" x-model="newPassword"
                       autocomplete="new-password" minlength="10" required
                       class="block w-full rounded-md border border-bronze/30 bg-white px-3 py-2 text-sm text-ink focus:border-bronze focus:outline-none focus:ring-1 focus:ring-bronze" />
                <p class="text-xs text-ink-soft">At least 10 characters.</p>
                <div class="flex justify-end gap-2 pt-2">
                    <button type="button" @@click="resetFor = null"
                            class="rounded-md border border-bronze/30 bg-white px-4 py-2 text-sm text-ink hover:bg-parchment">
                        Cancel
                    </button>
                    <button type="submit"
                            :disabled="newPassword.length < 10"
                            class="rounded-md bg-bronze px-4 py-2 text-sm font-medium text-white hover:bg-bronze-deep disabled:opacity-50">
                        Set password
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Delete user modal -->
    <div x-cloak x-show="deleteFor !== null"
         class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 p-4"
         @@keydown.escape.window="deleteFor = null"
         @@click.self="deleteFor = null">
        <div class="w-full max-w-sm rounded-lg bg-white p-6 shadow-xl ring-1 ring-bronze/20">
            <h3 class="text-lg font-semibold text-red-700">Delete user?</h3>
            <p class="mt-2 text-sm text-ink-soft">
                Permanently removes the account. If the user still owns
                events, delete those events first so storage files don&rsquo;t
                orphan.
            </p>
            <form method="post" asp-page-handler="DeleteUser" class="mt-4 space-y-3">
                <input type="hidden" name="userId" :value="deleteFor" />
                <div class="flex justify-end gap-2 pt-2">
                    <button type="button" @@click="deleteFor = null"
                            class="rounded-md border border-bronze/30 bg-white px-4 py-2 text-sm text-ink hover:bg-parchment">
                        Cancel
                    </button>
                    <button type="submit"
                            class="rounded-md bg-red-700 px-4 py-2 text-sm font-medium text-white hover:bg-red-800">
                        Delete user
                    </button>
                </div>
            </form>
        </div>
    </div>
</section>
