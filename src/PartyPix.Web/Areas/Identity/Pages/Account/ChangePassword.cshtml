@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change password";
}

<section class="mx-auto max-w-md px-4 py-16">
    <h1 class="text-3xl font-semibold tracking-tight text-bronze">Change password</h1>
    <p class="mt-1 text-sm text-ink-soft">Pick something at least 10 characters long.</p>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="mt-6 rounded-md bg-green-50 px-3 py-2 text-sm text-green-700">@Model.StatusMessage</div>
    }

    <form method="post" class="mt-8 space-y-4">
        <div asp-validation-summary="All" class="rounded-md bg-red-50 px-3 py-2 text-sm text-red-700 empty:hidden"></div>

        <div>
            <label asp-for="Input.OldPassword" class="block text-sm font-medium text-ink">Current password</label>
            <input asp-for="Input.OldPassword" autocomplete="current-password" type="password"
                   class="mt-1 block w-full rounded-md border border-bronze/30 bg-white px-3 py-2 text-sm text-ink shadow-sm focus:border-bronze focus:outline-none focus:ring-1 focus:ring-bronze" />
            <span asp-validation-for="Input.OldPassword" class="mt-1 block text-xs text-red-700"></span>
        </div>

        <div>
            <label asp-for="Input.NewPassword" class="block text-sm font-medium text-ink">New password</label>
            <input asp-for="Input.NewPassword" autocomplete="new-password" type="password"
                   class="mt-1 block w-full rounded-md border border-bronze/30 bg-white px-3 py-2 text-sm text-ink shadow-sm focus:border-bronze focus:outline-none focus:ring-1 focus:ring-bronze" />
            <span asp-validation-for="Input.NewPassword" class="mt-1 block text-xs text-red-700"></span>
        </div>

        <div>
            <label asp-for="Input.ConfirmPassword" class="block text-sm font-medium text-ink">Confirm new password</label>
            <input asp-for="Input.ConfirmPassword" autocomplete="new-password" type="password"
                   class="mt-1 block w-full rounded-md border border-bronze/30 bg-white px-3 py-2 text-sm text-ink shadow-sm focus:border-bronze focus:outline-none focus:ring-1 focus:ring-bronze" />
            <span asp-validation-for="Input.ConfirmPassword" class="mt-1 block text-xs text-red-700"></span>
        </div>

        <button type="submit"
                class="w-full rounded-md bg-bronze px-4 py-2 text-sm font-medium text-white hover:bg-bronze-deep">
            Change password
        </button>
    </form>
</section>
