@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot password";
}

<section class="mx-auto max-w-md px-4 py-16">
    <h1 class="text-3xl font-semibold tracking-tight text-bronze">Forgot password</h1>
    <p class="mt-4 text-sm text-ink">
        PartyPix doesn&rsquo;t send password-reset emails. Contact your event
        admin and they can set a new password for you from the dashboard.
    </p>

    <a asp-page="./Login"
       class="mt-6 inline-block rounded-md border border-bronze/40 bg-white px-4 py-2 text-sm text-ink hover:bg-parchment">
        Back to sign in
    </a>
</section>
