<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*"
             modules="AspNetCoreModuleV2"
             resourceType="Unspecified" />
      </handlers>

      <!-- In-process hosting: IIS loads the managed app directly into the
           worker process. processPath is relative to the app folder. -->
      <aspNetCore processPath=".\PartyPix.Web.exe"
                  arguments=""
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        </environmentVariables>
      </aspNetCore>

      <!-- 500 MB ceiling for tus upload chunks + originals. Cloudflare still
           caps public request bodies at 100 MB on Free/Pro, so tus-js-client
           is configured to send 5 MB chunks. -->
      <security>
        <requestFiltering>
          <requestLimits maxAllowedContentLength="524288000" />
        </requestFiltering>
      </security>

      <!-- Required for SignalR WebSocket transport. The IIS "WebSocket
           Protocol" role service must also be installed on the server. -->
      <webSocket enabled="true" />

      <!-- The gated /media/{id}/thumb|display endpoints set their own
           Cache-Control headers. Avoid IIS static-file caching stepping on
           them. -->
      <staticContent>
        <clientCache cacheControlMode="NoControl" />
      </staticContent>
    </system.webServer>
  </location>
</configuration>
